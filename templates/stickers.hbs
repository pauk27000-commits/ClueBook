{{#each stickers}}
<div class="cb-sticker {{#if this.isCollapsed}}is-collapsed{{/if}}" data-id="{{this.id}}" data-color="{{this.color}}" style="left: {{this.x}}px; top: {{this.y}}px;{{#if this.w}} width: {{this.w}}px;{{/if}}{{#if this.h}}{{#unless this.isCollapsed}} height: {{this.h}}px;{{/unless}}{{/if}}">
  <div class="cb-sticker-header">
    <div class="cb-sticker-header-controls">
      <a class="cb-sticker-btn btn-pin {{#if this.isPinnedToScene}}active{{/if}}" title="{{#if this.isPinnedToScene}}{{localize "CLUEBOOK.Sticker.MakeGlobal"}}{{else}}{{localize "CLUEBOOK.Sticker.PinToScene"}}{{/if}}">
        <i class="fas fa-thumbtack"></i>
      </a>
      <div class="cb-sticker-color-trigger">
        <a class="cb-sticker-btn btn-color" title="{{localize "CLUEBOOK.Sticker.Color"}}">
          <i class="fas fa-palette"></i>
        </a>
        <div class="cb-sticker-color-palette">
          <div class="color-dot" data-color="yellow" style="background: #ffd940;"></div>
          <div class="color-dot" data-color="red" style="background: #ff6b6b;"></div>
          <div class="color-dot" data-color="green" style="background: #7add80;"></div>
          <div class="color-dot" data-color="blue" style="background: #6bccff;"></div>
          <div class="color-dot" data-color="purple" style="background: #d47aec;"></div>
          <div class="color-dot" data-color="orange" style="background: #ffb642;"></div>
          <div class="color-dot" data-color="teal" style="background: #51e0d3;"></div>
          <div class="color-dot" data-color="pink" style="background: #ff80b3;"></div>
          <div class="color-dot" data-color="brown" style="background: #b99384;"></div>
        </div>
      </div>
    </div>
    <div class="cb-sticker-header-controls">
      <a class="cb-sticker-btn btn-collapse" title="{{#if this.isCollapsed}}{{localize "CLUEBOOK.Sticker.Expand"}}{{else}}{{localize "CLUEBOOK.Sticker.Collapse"}}{{/if}}">
        <i class="fas {{#if this.isCollapsed}}fa-chevron-down{{else}}fa-chevron-up{{/if}}"></i>
      </a>
      <a class="cb-sticker-btn btn-close" title="{{localize "CLUEBOOK.Sticker.Delete"}}">
        <i class="fas fa-times"></i>
      </a>
    </div>
  </div>
  <div class="cb-sticker-body">
    <input type="text" class="cb-sticker-title" placeholder="{{localize "CLUEBOOK.Sticker.TitlePlaceholder"}}" value="{{this.title}}" />
    <textarea class="cb-sticker-text" placeholder="{{localize "CLUEBOOK.Sticker.TextPlaceholder"}}">{{this.text}}</textarea>
    
    <div class="cb-sticker-divider"></div>
    
    <!-- Checklist -->
    <div class="cb-sticker-checklist">
      {{#each this.checklist}}
      <div class="cb-sticker-task-item {{#if this.checked}}is-checked{{/if}}" data-task-id="{{this.id}}">
        <input type="checkbox" class="cb-sticker-task-checkbox" {{#if this.checked}}checked{{/if}} />
        <input type="text" class="cb-sticker-task-input" placeholder="{{localize "CLUEBOOK.Sticker.TaskPlaceholder"}}" value="{{this.text}}" />
        <a class="cb-sticker-task-delete" title="{{localize "CLUEBOOK.Sticker.DeleteTask"}}"><i class="fas fa-trash-alt"></i></a>
      </div>
      {{/each}}
      <div class="cb-sticker-add-task-btn">
        <i class="fas fa-plus"></i> {{localize "CLUEBOOK.Sticker.AddTask"}}
      </div>
    </div>

    <!-- Entity Links -->
    {{#if this.links.length}}
    <div class="cb-sticker-divider"></div>
    <div class="cb-sticker-links">
      {{#each this.links}}
      <div class="cb-sticker-link-chip" data-uuid="{{this.uuid}}" title="{{localize "CLUEBOOK.Sticker.ClickToOpen"}}">
        <i class="fas fa-link"></i> {{this.name}}
        <a class="cb-sticker-link-delete" title="{{localize "CLUEBOOK.Sticker.Unlink"}}"><i class="fas fa-times"></i></a>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </div>
</div>
{{/each}}
