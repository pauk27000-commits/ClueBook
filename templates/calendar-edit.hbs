<form class="qn-calendar-edit-form">
  <div class="form-group">
    <label>Дата:</label>
    <input type="text" name="date" value="{{date}}">
  </div>
  <div class="form-group">
    <label>Время:</label>
    <input type="text" name="time" value="{{time}}">
  </div>
  <div class="form-group">
    <label>Погода:</label>
    <select name="weatherPreset">
      {{#each weatherPresets}}
        <option value="{{this.id}}" {{#if (eq this.id ../currentWeatherId)}}selected{{/if}}>{{this.name}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Температура (°C):</label>
    <input type="number" name="temperature" value="{{temperature}}">
  </div>
  <div class="form-group">
    <label>Сезон:</label>
    <select name="seasonPreset">
      {{#each seasonPresets}}
        <option value="{{this.id}}" {{#if (eq this.id ../currentSeasonId)}}selected{{/if}}>{{this.name}}</option>
      {{/each}}
    </select>
  </div>
</form>
