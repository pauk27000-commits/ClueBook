<div class="tab active {{#if isBoardView}}board-canvas{{/if}}" data-tab="{{activeTab}}">
  
  {{#if isWorkspaces}}
  <div class="settings-container">
    <h2><i class="fas fa-layer-group"></i> Доски (Рабочие пространства)</h2>
    <p class="settings-hint">
      Здесь вы можете переключаться между личным блокнотом и общими досками, а также создавать новые.
    </p>

    <div class="settings-section">
      <h3>Текущая доска</h3>
      <div class="setting-row">
        <label>Выбранная доска:</label>
        <select id="qn-workspace-select" class="setting-input" style="flex: 1;">
          {{#each workspaces}}
            <option value="{{this.id}}" {{#if (eq this.id ../activeWorkspace)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
        <button type="button" data-action="renameWorkspace" title="Переименовать доску" style="width: auto; padding: 0 10px; margin-left: 10px; cursor: pointer; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
          <i class="fas fa-edit"></i>
        </button>
      </div>
    </div>

    <div class="settings-section">
      <h3>Новая доска</h3>
      <div class="setting-row" style="justify-content: flex-start;">
        <button id="qn-workspace-create" type="button" style="width: auto; padding: 0 15px; margin-right: auto; cursor: pointer;">
          <i class="fas fa-plus"></i> Создать новую доску
        </button>
      </div>
      <p class="settings-hint" style="margin-top: 5px;">Создайте новую общую доску и пригласите в нее нужных игроков.</p>
    </div>

    {{#if isGM}}
    <div class="settings-section">
      <h3>Экспорт и Импорт сценариев (JSON)</h3>
      <div class="setting-row" style="justify-content: flex-start; gap: 10px; flex-wrap: wrap;">
        <button type="button" data-action="importJSON" style="width: auto; padding: 0 15px; cursor: pointer; background: rgba(123, 97, 255, 0.3); border: 1px solid var(--qn-accent);">
          <i class="fas fa-robot"></i> Вставить JSON
        </button>
        <button type="button" data-action="exportJSON" style="width: auto; padding: 0 15px; cursor: pointer; background: rgba(0, 150, 136, 0.3); border: 1px solid #009688;">
          <i class="fas fa-download"></i> Экспорт доски
        </button>
        <button type="button" data-action="copyAIPrompt" style="width: auto; padding: 0 15px; cursor: pointer; background: rgba(0, 0, 0, 0.3); border: 1px solid #555;">
          <i class="fas fa-copy"></i> Промпт для нейросети
        </button>
      </div>
      <p class="settings-hint" style="margin-top: 5px;">Вы можете экспортировать текущую доску в JSON файл для бекапа или поделиться с другими Мастерами.</p>
    </div>
    {{/if}}
  </div>
  {{/if}}
  {{#if isSettings}}
  <div class="settings-container">
    <h2><i class="fas fa-cog"></i> Настройки {{#if isShared}}(Общие){{else}}(Личные){{/if}}</h2>
    <p class="settings-hint">
      {{#if isShared}}Здесь вы настраиваете общий блокнот. Эти изменения (вкладки, цвета по умолчанию) увидят все игроки. Эстетика окна всегда личная.{{else}}Здесь вы настраиваете свой личный блокнот. Никто другой этого не увидит.{{/if}}
    </p>

    <div class="settings-section">
      <h3><i class="fas fa-paint-brush"></i> Внешний вид (Лично для вас)</h3>
      <div class="setting-row">
        <label>Акцентный цвет</label>
        <select class="setting-input quicknotes-input" data-key="theme.accent">
          <option value="#7b61ff" {{#if (eq settings.theme.accent "#7b61ff")}}selected{{/if}}>Фиолетовый</option>
          <option value="#ff5252" {{#if (eq settings.theme.accent "#ff5252")}}selected{{/if}}>Красный</option>
          <option value="#4caf50" {{#if (eq settings.theme.accent "#4caf50")}}selected{{/if}}>Зеленый</option>
          <option value="#2196f3" {{#if (eq settings.theme.accent "#2196f3")}}selected{{/if}}>Синий</option>
          <option value="#ff9800" {{#if (eq settings.theme.accent "#ff9800")}}selected{{/if}}>Оранжевый</option>
        </select>
      </div>
      <div class="setting-row">
        <label>Прозрачность фона (Эффект стекла)</label>
        <input type="range" class="setting-input" data-key="theme.opacity" min="40" max="100" value="{{settings.theme.opacity}}">
      </div>
      <div class="setting-row">
        <label>Цвет нитей (Связей)</label>
        <input type="color" class="setting-input" data-key="theme.linkColor" value="{{settings.theme.linkColor}}" style="height: 30px; cursor: pointer;">
      </div>
      <div class="setting-row">
        <label>Стиль нитей</label>
        <select class="setting-input quicknotes-input" data-key="theme.linkStyle">
          <option value="solid" {{#if (eq settings.theme.linkStyle "solid")}}selected{{/if}}>Сплошная</option>
          <option value="6,4" {{#if (eq settings.theme.linkStyle "6,4")}}selected{{/if}}>Пунктир</option>
          <option value="2,4" {{#if (eq settings.theme.linkStyle "2,4")}}selected{{/if}}>Точки</option>
        </select>
      </div>
      <div class="setting-row flex-checkbox">
        <label>Показывать подсказки на доске</label>
        <input type="checkbox" class="setting-input" data-key="theme.showHotkeys" {{#if settings.theme.showHotkeys}}checked{{/if}}>
      </div>
      <div class="setting-row flex-checkbox">
        <label>Привязка к сетке (Snap-to-Grid)</label>
        <input type="checkbox" class="setting-input" data-key="theme.snapToGrid" {{#if settings.theme.snapToGrid}}checked{{/if}}>
      </div>
      <div class="setting-row">
        <label>Длительность подсветки (сек)</label>
        <input type="number" class="setting-input" data-key="theme.highlightDuration" value="{{settings.theme.highlightDuration}}" min="1" max="10" step="1">
      </div>
    </div>

    <div class="settings-section">
      <h3><i class="fas fa-eye"></i> Видимость вкладок</h3>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="visibility.npc" {{#if settings.visibility.npc}}checked{{/if}}>
        <label>Персонажи (NPC)</label>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="visibility.quests" {{#if settings.visibility.quests}}checked{{/if}}>
        <label>Квесты</label>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="visibility.timeline" {{#if settings.visibility.timeline}}checked{{/if}}>
        <label>Хронология</label>
      </div>
    </div>

    <div class="settings-section">
      <h3><i class="fas fa-palette"></i> Цвет заметок по умолчанию</h3>
      <div class="setting-row">
        <label>Заметки</label>
        <select class="setting-input quicknotes-input" data-key="defaultColors.notes">
          <option value="yellow" {{#if (eq settings.defaultColors.notes "yellow")}}selected{{/if}}>Желтый</option>
          <option value="green" {{#if (eq settings.defaultColors.notes "green")}}selected{{/if}}>Зеленый</option>
          <option value="blue" {{#if (eq settings.defaultColors.notes "blue")}}selected{{/if}}>Синий</option>
          <option value="red" {{#if (eq settings.defaultColors.notes "red")}}selected{{/if}}>Красный</option>
          <option value="purple" {{#if (eq settings.defaultColors.notes "purple")}}selected{{/if}}>Фиолетовый</option>
        </select>
      </div>
      <div class="setting-row">
        <label>Персонажи</label>
        <select class="setting-input quicknotes-input" data-key="defaultColors.npc">
          <option value="yellow" {{#if (eq settings.defaultColors.npc "yellow")}}selected{{/if}}>Желтый</option>
          <option value="green" {{#if (eq settings.defaultColors.npc "green")}}selected{{/if}}>Зеленый</option>
          <option value="blue" {{#if (eq settings.defaultColors.npc "blue")}}selected{{/if}}>Синий</option>
          <option value="red" {{#if (eq settings.defaultColors.npc "red")}}selected{{/if}}>Красный</option>
          <option value="purple" {{#if (eq settings.defaultColors.npc "purple")}}selected{{/if}}>Фиолетовый</option>
        </select>
      </div>

      <div class="setting-row">
        <label>Квесты</label>
        <select class="setting-input quicknotes-input" data-key="defaultColors.quests">
          <option value="yellow" {{#if (eq settings.defaultColors.quests "yellow")}}selected{{/if}}>Желтый</option>
          <option value="green" {{#if (eq settings.defaultColors.quests "green")}}selected{{/if}}>Зеленый</option>
          <option value="blue" {{#if (eq settings.defaultColors.quests "blue")}}selected{{/if}}>Синий</option>
          <option value="red" {{#if (eq settings.defaultColors.quests "red")}}selected{{/if}}>Красный</option>
          <option value="purple" {{#if (eq settings.defaultColors.quests "purple")}}selected{{/if}}>Фиолетовый</option>
        </select>
      </div>
      <div class="setting-row">
        <label>Хронология</label>
        <select class="setting-input quicknotes-input" data-key="defaultColors.timeline">
          <option value="yellow" {{#if (eq settings.defaultColors.timeline "yellow")}}selected{{/if}}>Желтый</option>
          <option value="green" {{#if (eq settings.defaultColors.timeline "green")}}selected{{/if}}>Зеленый</option>
          <option value="blue" {{#if (eq settings.defaultColors.timeline "blue")}}selected{{/if}}>Синий</option>
          <option value="red" {{#if (eq settings.defaultColors.timeline "red")}}selected{{/if}}>Красный</option>
          <option value="purple" {{#if (eq settings.defaultColors.timeline "purple")}}selected{{/if}}>Фиолетовый</option>
        </select>
      </div>
    </div>

    <div class="settings-section">
      <h3><i class="fas fa-bolt"></i> Быстрые кнопки виджета</h3>
      <div class="setting-row">
        <label>Направление разлета</label>
        <select class="setting-input quicknotes-input" data-key="widget.direction">
          <option value="up-right" {{#if (eq settings.widget.direction "up-right")}}selected{{/if}}>Вверх и вправо ↗️</option>
          <option value="up-left" {{#if (eq settings.widget.direction "up-left")}}selected{{/if}}>Вверх и влево ↖️</option>
          <option value="down-right" {{#if (eq settings.widget.direction "down-right")}}selected{{/if}}>Вниз и вправо ↘️</option>
          <option value="down-left" {{#if (eq settings.widget.direction "down-left")}}selected{{/if}}>Вниз и влево ↙️</option>
        </select>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="widget.showNotes" {{#if settings.widget.showNotes}}checked{{/if}}>
        <label>Заметка</label>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="widget.showNpc" {{#if settings.widget.showNpc}}checked{{/if}}>
        <label>Персонаж (NPC)</label>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="widget.showQuests" {{#if settings.widget.showQuests}}checked{{/if}}>
        <label>Квест</label>
      </div>
      <div class="setting-row flex-checkbox">
        <input type="checkbox" class="setting-input" data-key="widget.showTimeline" {{#if settings.widget.showTimeline}}checked{{/if}}>
        <label>Хронология</label>
      </div>
    </div>
    </div>

    {{#if isShared}}
    {{#if isGM}}
    <div class="settings-section">
      <h3>Права доступа (только для GM)</h3>
      <div class="setting-row flex-checkbox">
        <label>Режим "Только чтение" для игроков</label>
        <input type="checkbox" class="setting-input" data-key="readOnly" {{#if settings.readOnly}}checked{{/if}}>
      </div>
      <p class="settings-hint">Если включено, игроки смогут только смотреть доску (не смогут добавлять, двигать, изменять текст или связи).</p>
    </div>
    {{/if}}
    {{/if}}
  </div>
  {{else}}
  {{#if (eq activeTab "search")}}
  <div class="search-container" style="padding: 10px; background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.1);">
    <i class="fas fa-search search-icon"></i>
    <input type="text" id="quicknotes-search" class="quicknotes-search-input" placeholder="Поиск по всем записям..." value="{{searchQuery}}">
  </div>
  {{/if}}

  {{#if isBoardView}}
  <button class="board-recenter-btn" title="Вернуться в центр" data-action="recenterBoard">
    <i class="fas fa-crosshairs"></i>
  </button>
  {{/if}}

  <div class="entries-list">
    {{#if isBoardView}}
    <svg class="board-svg" width="100%" height="100%" style="position:absolute; top:0; left:0; overflow: visible; pointer-events:none; z-index:1;">
      {{#each links}}
      <g class="board-link" data-source="{{this.source}}" data-target="{{this.target}}" style="pointer-events: auto; cursor: pointer;" title="ЛКМ: текст связи, ПКМ: удалить связь">
        <line data-source="{{this.source}}" data-target="{{this.target}}" stroke="transparent" stroke-width="20" />
        <line data-source="{{this.source}}" data-target="{{this.target}}" stroke="{{../settings.theme.linkColor}}" stroke-width="3" stroke-dasharray="{{#if (eq ../settings.theme.linkStyle 'solid')}}none{{else}}{{../settings.theme.linkStyle}}{{/if}}" />
      </g>
      {{/each}}
    </svg>
    <div class="board-link-labels" style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:2;">
      {{#each links}}
        {{#if this.label}}
          <div class="board-link-label" data-source="{{this.source}}" data-target="{{this.target}}" style="position: absolute; transform: translate(-50%, -50%); background: rgba(0,0,0,0.8); color: white; padding: 4px 8px; border-radius: 6px; pointer-events: auto; cursor: pointer; white-space: nowrap; font-size: 14px; border: 1px solid {{../settings.theme.linkColor}};" title="ЛКМ: изменить текст, ПКМ: удалить связь">
            {{this.label}}
          </div>
        {{/if}}
      {{/each}}
    </div>
    {{/if}}

    {{#each entries}}
      <div class="quicknotes-entry {{#if (eq this.id ../editingEntryId)}}is-editing{{/if}} {{#if this.isHidden}}is-hidden{{/if}} {{#if (eq this.id ../highlightedEntryId)}}is-highlighted{{/if}}" data-entry-id="{{this.id}}" data-source-tab="{{this.sourceTab}}" data-color="{{this.color}}" data-on-board="{{this.onBoard}}" {{#unless ../isBoardView}}draggable="true"{{/unless}} {{#if ../isBoardView}}style="position: absolute; left: {{this.boardX}}px; top: {{this.boardY}}px; z-index: 10; {{#if (eq this.id ../highlightedEntryId)}}animation-duration: {{../settings.theme.highlightDuration}}s; z-index: 100;{{/if}}"{{/if}}>
        <div class="sticky-pin"></div>
        {{#unless ../isReadOnly}}
        <div class="entry-controls">
          {{#if ../isGM}}
          <a data-action="toggleVisibility" class="btn-visibility" title="{{#if this.isHidden}}Показать игрокам{{else}}Скрыть от игроков{{/if}}"><i class="fas {{#if this.isHidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i></a>
          {{/if}}
          <a data-action="toggleEdit" class="btn-edit" title="Редактировать"><i class="fas fa-pencil-alt"></i></a>
          {{#if ../isBoardView}}
          <a class="btn-link" title="Связать ниткой"><i class="fas fa-link"></i></a>
          <a data-action="removeFromBoard" class="btn-remove-board" title="Убрать с доски"><i class="fas fa-times"></i></a>
          {{else}}
          {{#if this.onBoard}}
          <a data-action="jumpToBoard" class="btn-jump" title="Найти на доске"><i class="fas fa-map-marker-alt"></i></a>
          {{/if}}
          <a data-action="sendToBoard" class="btn-board {{#if this.onBoard}}active{{/if}}" title="Отправить на доску"><i class="fas fa-project-diagram"></i></a>
          <a data-action="deleteEntry" class="btn-delete" title="Удалить запись"><i class="fas fa-trash"></i></a>
          {{/if}}
        </div>
        {{/unless}}
        
        <div class="entry-content" {{#if ../isBoardView}}style="{{#if this.boardW}}width: {{this.boardW}}px;{{/if}} {{#if this.boardH}}height: {{this.boardH}}px;{{/if}}"{{/if}}>
          <!-- View Mode -->
          <div class="view-mode">
            {{#if (eq this.sourceTab "notes")}}
              <div class="display-text">{{{this.enriched.text}}}</div>
            {{/if}}

            {{#if (eq this.sourceTab "npc")}}
              <div class="display-title">{{this.name}}</div>
              <div class="display-meta"><i class="fas fa-map-marker-alt"></i> {{this.location}}</div>
              <div class="display-meta"><i class="fas fa-smile"></i> {{this.attitude}}</div>
              <div class="display-text">{{{this.enriched.note}}}</div>
            {{/if}}


            {{#if (eq this.sourceTab "quests")}}
              <div class="display-badge badge-{{this.status}}">{{this.status}}</div>
              <div class="display-text">{{{this.enriched.text}}}</div>
            {{/if}}

            {{#if (eq this.sourceTab "timeline")}}
              <div class="display-meta"><i class="fas fa-clock"></i> {{this.time}}</div>
              <div class="timeline-event">{{{this.enriched.event}}}</div>
            {{/if}}
            
            {{#if ../isGM}}
              {{#if this.gmNotes}}
                <div class="display-gm-notes" style="margin-top: 10px; padding: 5px 8px; background: rgba(255,82,82,0.1); border-left: 3px solid #ff5252; font-size: 0.9em; border-radius: 0 4px 4px 0;">
                  <strong style="color: #ff5252; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.5px;"><i class="fas fa-user-secret"></i> Секретно (GM):</strong>
                  <div style="margin-top: 4px; opacity: 0.9;">{{{this.enriched.gmNotes}}}</div>
                </div>
              {{/if}}
            {{/if}}
          </div>

          <!-- Edit Mode -->
          {{#unless ../isReadOnly}}
          <div class="edit-mode">
            <div class="color-palette">
              <div class="color-swatch color-yellow" data-action="selectColor" data-color="yellow" title="Желтый"></div>
              <div class="color-swatch color-red" data-action="selectColor" data-color="red" title="Красный (Срочно)"></div>
              <div class="color-swatch color-green" data-action="selectColor" data-color="green" title="Зеленый (NPC)"></div>
              <div class="color-swatch color-blue" data-action="selectColor" data-color="blue" title="Синий (Лор)"></div>
              <div class="color-swatch color-purple" data-action="selectColor" data-color="purple" title="Фиолетовый"></div>
            </div>

            {{#if (eq this.sourceTab "notes")}}
              <textarea class="quicknotes-input" data-field="text" placeholder="Текст заметки...">{{this.text}}</textarea>
            {{/if}}

            {{#if (eq this.sourceTab "npc")}}
              <input type="text" class="quicknotes-input" data-field="name" value="{{this.name}}" placeholder="Имя">
              <input type="text" class="quicknotes-input" data-field="location" value="{{this.location}}" placeholder="Локация">
              <input type="text" class="quicknotes-input" data-field="attitude" value="{{this.attitude}}" placeholder="Отношение">
              <textarea class="quicknotes-input" data-field="note" placeholder="Заметки о персонаже...">{{this.note}}</textarea>
            {{/if}}


            {{#if (eq this.sourceTab "quests")}}
              <div class="flexrow">
                <select class="quicknotes-input status-select" data-field="status">
                  <option value="active" {{#if (eq this.status "active")}}selected{{/if}}>Активно</option>
                  <option value="completed" {{#if (eq this.status "completed")}}selected{{/if}}>Выполнено</option>
                  <option value="failed" {{#if (eq this.status "failed")}}selected{{/if}}>Провалено</option>
                </select>
              </div>
              <textarea class="quicknotes-input" data-field="text" placeholder="Описание квеста...">{{this.text}}</textarea>
            {{/if}}

            {{#if (eq this.sourceTab "timeline")}}
              <input type="text" class="quicknotes-input time-input" data-field="time" value="{{this.time}}" placeholder="Время/Дата">
              <textarea class="quicknotes-input" data-field="event" placeholder="Описание события...">{{this.event}}</textarea>
            {{/if}}
            
            {{#if ../isGM}}
              <div style="margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px;">
                <label style="color: #ff5252; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.5px; font-weight: bold;"><i class="fas fa-user-secret"></i> Секретные заметки (GM)</label>
                <textarea class="quicknotes-input" data-field="gmNotes" placeholder="Только для мастера..." style="border-left: 2px solid #ff5252; background: rgba(255,82,82,0.05); margin-top: 5px;">{{this.gmNotes}}</textarea>
              </div>
            {{/if}}
          </div>
          {{/unless}}
        </div>
      </div>
    {{/each}}
  </div>

  {{#unless isReadOnly}}
  {{#if showAddBtn}}
  <div class="add-entry-btn-container">
    <button type="button" data-action="addEntry">
      <i class="fas fa-plus"></i> Добавить запись
    </button>
  </div>
  {{/if}}
  {{/unless}}

  {{#if isBoardView}}
  {{#if settings.theme.showHotkeys}}
  <div class="board-hotkeys-hint" style="position: absolute; bottom: 20px; right: 20px; background: rgba(0,0,0,0.6); padding: 10px; border-radius: 8px; color: #fff; font-size: 12px; pointer-events: auto; z-index: 1000; display: flex; flex-direction: column; gap: 5px;">
    <div style="text-align: right; margin-bottom: -5px; opacity: 0.7;">
      <i class="fas fa-times" data-action="hideHotkeys" style="cursor: pointer;" title="Скрыть подсказки (можно вернуть в Настройках)"></i>
    </div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">ЛКМ</kbd> Перетаскивание</div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">Shift</kbd> Привязка к сетке</div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">Колесико</kbd> Масштаб</div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">ПКМ / СКМ</kbd> Двигать холст</div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">ЛКМ (нить)</kbd> Текст связи</div>
    <div><kbd style="background:#444; border-radius:3px; padding:2px 4px;">ПКМ (нить)</kbd> Удалить связь</div>
  </div>
  {{/if}}
  {{/if}}
  {{/if}}
</div>
